VITE_SOLUTION_FINDER_WEBHOOK=https://n8n.getvoidra.com/webhook/nox-solution-finder

# APP-X-BRIDGE-02 — Operator API auth gate
# Server-side only. Never prefix with VITE_. Never commit a real value.
# If unset/empty, /api/operator/* responds 503 service_unavailable.
NOX_OPERATOR_API_KEY=

# APP-X-BRIDGE-04a/04c — Notion read-only project context adapter
# Server-side only. Never prefix with VITE_. Never commit a real value.
# NOX_NOTION_READONLY_TOKEN must be a SEPARATE Notion integration with
#   read-only scope, connected to Master Tasks and (for relation mode)
#   to the Projects DB. Never reuse the write-capable bridge token.
NOX_NOTION_READONLY_TOKEN=
# Master Tasks database ID. Not a secret per se, but always set via env,
# never hardcoded.
NOX_MASTER_TASKS_DB_ID=
# Projects ("🧭 Projects / System Map") database ID. Required only when
# NOX_PROJECT_MAPPING_MODE=notion-relation. Not a secret.
NOX_PROJECTS_DB_ID=
# Project mapping strategy. Options:
#   none           — empty projection, explained in contextSummary (default)
#   title-prefix   — match `[id] ...`, `id: ...`, `id —/- ...` in quest titles
#   notion-relation — canonical: Projects-DB lookup + Project relation filter
NOX_PROJECT_MAPPING_MODE=

# APP-X-BRIDGE-04d — Notion fetch hardening
# Per-request abort timeout for outbound Notion calls. Default 8000 ms.
# Clamped to [1000, 15000] ms. Leave empty to use the default.
NOX_NOTION_FETCH_TIMEOUT_MS=
